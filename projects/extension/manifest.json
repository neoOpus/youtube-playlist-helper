{
  "name": "YouTube Playlist Helper",
  "description": "YouTube playlist editor and generator - Quantum Edition",
  "version": "3.0.0",
  "manifest_version": 3,
  "icons": {
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_title": "YouTube Playlist Helper",
    "default_popup": "editor/index.html"
  },
  "background": {
    "service_worker": "editor/build/background.js",
    "type": "module"
  },
  "permissions": [
    "bookmarks",
    "tabs",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://www.youtube.com/watch*",
    "https://www.youtube.com/playlist*"
  ]
}
