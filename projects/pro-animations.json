{
  "name": "Professional Edition Motion Spec",
  "version": "1.0.0",
  "animations": [
    {
      "id": "card-entry",
      "properties": ["opacity", "transform"],
      "from": { "opacity": 0, "transform": "scale(0.98) translateY(10px)" },
      "to": { "opacity": 1, "transform": "scale(1) translateY(0)" },
      "duration": 400,
      "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    {
      "id": "luminous-hover",
      "properties": ["opacity"],
      "duration": 300,
      "easing": "linear",
      "description": "Cursor-tracking radial gradient expansion"
    },
    {
      "id": "button-press",
      "properties": ["transform"],
      "from": { "transform": "scale(1)" },
      "to": { "transform": "scale(0.96)" },
      "duration": 100,
      "easing": "ease-out"
    },
    {
      "id": "toast-slide-in",
      "properties": ["transform", "opacity"],
      "from": { "transform": "translateY(100%)", "opacity": 0 },
      "to": { "transform": "translateY(0)", "opacity": 1 },
      "duration": 500,
      "easing": "cubic-bezier(0.23, 1, 0.32, 1)"
    },
    {
      "id": "aura-pulse",
      "properties": ["opacity", "transform"],
      "keyframes": [
        { "offset": 0, "opacity": 0.5, "transform": "scale(1)" },
        { "offset": 0.5, "opacity": 1, "transform": "scale(1.05)" },
        { "offset": 1, "opacity": 0.5, "transform": "scale(1)" }
      ],
      "duration": 2000,
      "iterations": "infinite"
    }
  ]
}
